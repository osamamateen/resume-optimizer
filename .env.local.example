# Required for Claude provider (AI_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-...

# Required for OpenRouter provider (AI_PROVIDER=openrouter)
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Optional: defaults shown
AI_PROVIDER=claude                                          # "claude" | "openrouter"
CLAUDE_MODEL=claude-sonnet-4-6
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free   # any free model id from openrouter.ai/models?q=free
OPENROUTER_APP_URL=http://localhost:3000
OPENROUTER_APP_NAME=Resume Optimizer

# Required: Postgres connection string (Prisma). Use a pooled connection
# (e.g. Supabase's Session or Transaction pooler) if the direct host is
# IPv6-only on your network.
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Required: JWT signing/hashing secrets. Generate each with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_HASH_SECRET=

# Required for Google sign-in. Create at https://console.cloud.google.com/apis/credentials
# (OAuth client ID, type "Web application"; add your dev/prod origin under
# Authorized JavaScript origins — no redirect URI needed).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
