# Required for Claude provider (AI_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-...

# Required for OpenRouter provider (AI_PROVIDER=openrouter)
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Optional: defaults shown
AI_PROVIDER=claude                                          # "claude" | "openrouter"
CLAUDE_MODEL=claude-sonnet-4-6
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free   # any free model id from openrouter.ai/models?q=free
OPENROUTER_APP_URL=http://localhost:3000
OPENROUTER_APP_NAME=Resume Optimizer
