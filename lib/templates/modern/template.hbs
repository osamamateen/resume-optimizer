<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>{{contact.name}} - Resume</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: Arial, Helvetica, sans-serif;
    color: #1a1a1a;
    background: #ffffff;
    -webkit-font-smoothing: antialiased;
  }

  .page {
    max-width: 850px;
    margin: 0 auto;
    padding: 55px 60px 60px 60px;
  }

  /* Header */
  .name {
    font-size: 26px;
    font-weight: 700;
    letter-spacing: 0.5px;
    color: #111;
  }

  .contact-line {
    font-size: 12.5px;
    color: #1a1a1a;
    margin-top: 6px;
    margin-bottom: 4px;
  }

  /* Section */
  .section {
    margin-top: 22px;
  }

  .section-title {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    border-bottom: 1.3px solid #1a1a1a;
    padding-bottom: 4px;
    margin-bottom: 10px;
  }

  .summary-text {
    font-size: 12.5px;
    line-height: 1.55;
    text-align: left;
    color: #1a1a1a;
  }

  /* Work experience / Projects */
  .job, .project {
    margin-bottom: 16px;
  }

  .job:last-child, .project:last-child {
    margin-bottom: 0;
  }

  .job-header, .project-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .job-title, .project-title {
    font-size: 13.5px;
    font-weight: 700;
  }

  .job-dates {
    font-size: 12.5px;
    font-style: italic;
    white-space: nowrap;
  }

  .job-company {
    font-size: 12.5px;
    font-style: italic;
    margin-bottom: 6px;
    margin-top: 1px;
  }

  .project-tech {
    font-size: 12.5px;
    font-style: italic;
    margin-bottom: 6px;
    margin-top: 1px;
  }

  .project-description {
    font-size: 12.5px;
    line-height: 1.55;
    margin-bottom: 6px;
  }

  ul.bullets {
    list-style: none;
    padding-left: 0;
    margin: 0;
  }

  ul.bullets li {
    font-size: 12.5px;
    line-height: 1.55;
    padding-left: 16px;
    position: relative;
    margin-bottom: 3px;
  }

  ul.bullets li::before {
    content: "•";
    position: absolute;
    left: 2px;
    top: 0;
  }

  /* Skills */
  .skills-line {
    font-size: 12.5px;
    line-height: 1.75;
  }

  .skills-line .label {
    font-weight: 700;
  }

  /* Education */
  .edu {
    margin-bottom: 10px;
  }

  .edu:last-child {
    margin-bottom: 0;
  }

  .edu-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .edu-degree {
    font-size: 13.5px;
    font-weight: 700;
  }

  .edu-dates {
    font-size: 12.5px;
    font-style: italic;
    white-space: nowrap;
  }

  .edu-school {
    font-size: 12.5px;
    font-style: italic;
    margin-top: 1px;
  }

  /* Custom sections */
  .custom-content {
    font-size: 12.5px;
    line-height: 1.55;
  }
</style>
</head>
<body>
<div class="page">

  <!-- Header -->
  <div class="name">{{contact.name}}</div>
  <div class="contact-line">
    {{contact.email}} | {{contact.phone}} | {{contact.location}}{{#if contact.linkedin}} | {{contact.linkedin}}{{/if}}{{#if contact.github}} | {{contact.github}}{{/if}}{{#if contact.website}} | {{contact.website}}{{/if}}
  </div>

  <!-- Summary -->
  {{#if summary}}
  <div class="section">
    <div class="section-title">Summary</div>
    <div class="summary-text">{{summary}}</div>
  </div>
  {{/if}}

  <!-- Work Experience -->
  {{#if experience.length}}
  <div class="section">
    <div class="section-title">Work Experience</div>

    {{#each experience}}
    <div class="job">
      <div class="job-header">
        <div class="job-title">{{this.title}}</div>
        <div class="job-dates">{{this.startDate}} – {{this.endDate}}</div>
      </div>
      <div class="job-company">{{this.company}}{{#if this.location}} | {{this.location}}{{/if}}</div>
      <ul class="bullets">
        {{#each this.bullets}}
        <li>{{this}}</li>
        {{/each}}
      </ul>
    </div>
    {{/each}}
  </div>
  {{/if}}

  <!-- Projects -->
  {{#if projects.length}}
  <div class="section">
    <div class="section-title">Projects</div>

    {{#each projects}}
    <div class="project">
      <div class="project-header">
        <div class="project-title">{{this.name}}</div>
      </div>
      {{#if this.technologies.length}}
      <div class="project-tech">{{#each this.technologies}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</div>
      {{/if}}
      {{#if this.description}}
      <div class="project-description">{{this.description}}</div>
      {{/if}}
      <ul class="bullets">
        {{#each this.bullets}}
        <li>{{this}}</li>
        {{/each}}
      </ul>
    </div>
    {{/each}}
  </div>
  {{/if}}

  <!-- Skills -->
  {{#if skills}}
  <div class="section">
    <div class="section-title">Skills</div>
    {{#if skills.languages.length}}
    <div class="skills-line"><span class="label">Languages:</span> {{#each skills.languages}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</div>
    {{/if}}
    {{#if skills.frameworks.length}}
    <div class="skills-line"><span class="label">Frameworks:</span> {{#each skills.frameworks}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</div>
    {{/if}}
    {{#if skills.tools.length}}
    <div class="skills-line"><span class="label">Tools:</span> {{#each skills.tools}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</div>
    {{/if}}
    {{#if skills.other.length}}
    <div class="skills-line"><span class="label">Other:</span> {{#each skills.other}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</div>
    {{/if}}
  </div>
  {{/if}}

  <!-- Education -->
  {{#if education.length}}
  <div class="section">
    <div class="section-title">Education</div>
    {{#each education}}
    <div class="edu">
      <div class="edu-header">
        <div class="edu-degree">{{this.degree}}{{#if this.field}}, {{this.field}}{{/if}}</div>
        <div class="edu-dates">{{this.graduationDate}}</div>
      </div>
      <div class="edu-school">{{this.institution}}</div>
    </div>
    {{/each}}
  </div>
  {{/if}}

  <!-- Custom Sections -->
  {{#if customSections.length}}
  {{#each customSections}}
  <div class="section">
    <div class="section-title">{{this.label}}</div>
    <div class="custom-content">{{this.content}}</div>
  </div>
  {{/each}}
  {{/if}}

</div>
</body>
</html>
