<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{contact.name}} — Resume</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'Inter', sans-serif;
      font-size: 10pt;
      color: #1a1a1a;
      background: #ffffff;
      width: 794px;
      margin: 0 auto;
      padding: 0;
      line-height: 1.5;
    }

    /* Decorative accent bar — purely visual, contains no text */
    .accent-bar {
      position: fixed;
      left: 0;
      top: 0;
      bottom: 0;
      width: 4px;
      background: #2563EB;
    }

    .page {
      padding: 40px 48px 48px 52px;
    }

    /* ── Header ── */
    header {
      margin-bottom: 20px;
    }

    header h1 {
      font-size: 22pt;
      font-weight: 700;
      color: #1a1a1a;
      line-height: 1.2;
      margin-bottom: 6px;
    }

    .contact-line {
      font-size: 9pt;
      color: #6B7280;
      line-height: 1.4;
    }

    .contact-line a {
      color: #6B7280;
      text-decoration: none;
    }

    /* ── Sections ── */
    .section {
      margin-top: 20px;
    }

    .section h2 {
      font-size: 9pt;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #2563EB;
      margin-bottom: 8px;
    }

    /* ── Summary ── */
    .summary-text {
      font-size: 10pt;
      color: #1a1a1a;
      line-height: 1.5;
    }

    /* ── Entries (experience, education, projects) ── */
    .entry {
      margin-bottom: 12px;
    }

    .entry:last-child {
      margin-bottom: 0;
    }

    .entry-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 8px;
    }

    .entry-title {
      font-size: 10pt;
      font-weight: 600;
      color: #1a1a1a;
    }

    .entry-date {
      font-size: 9pt;
      color: #6B7280;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .entry-sub {
      font-size: 9pt;
      color: #6B7280;
      margin-top: 1px;
      margin-bottom: 4px;
    }

    /* ── Bullets ── */
    .bullets {
      list-style: none;
      padding: 0;
      margin: 4px 0 0 0;
    }

    .bullets li {
      font-size: 10pt;
      color: #1a1a1a;
      line-height: 1.5;
      padding-left: 14px;
      position: relative;
      margin-bottom: 2px;
    }

    .dash {
      position: absolute;
      left: 0;
      top: 0;
    }

    /* ── Education ── */
    .edu-degree {
      font-size: 10pt;
      font-weight: 600;
      color: #1a1a1a;
    }

    .edu-date {
      font-size: 9pt;
      color: #6B7280;
      white-space: nowrap;
      flex-shrink: 0;
    }

    /* ── Skills ── */
    .skills-group {
      margin-bottom: 6px;
    }

    .skills-label {
      font-size: 9pt;
      font-weight: 600;
      color: #6B7280;
      margin-right: 6px;
    }

    .skill-pill {
      display: inline-block;
      background: #EFF6FF;
      color: #2563EB;
      border-radius: 3px;
      padding: 1px 6px;
      font-size: 9pt;
      margin: 2px 3px 2px 0;
    }

    /* ── Projects ── */
    .project-tech {
      font-size: 9pt;
      color: #6B7280;
      margin-top: 2px;
      margin-bottom: 4px;
    }

    .project-description {
      font-size: 10pt;
      color: #1a1a1a;
      margin-top: 2px;
      margin-bottom: 4px;
      line-height: 1.5;
    }

    /* ── Custom Sections ── */
    .custom-content {
      font-size: 10pt;
      color: #1a1a1a;
      line-height: 1.5;
    }
  </style>
</head>
<body>
  <div class="accent-bar"></div>

  <div class="page">

    <!-- ── Header ── -->
    <header>
      <h1>{{contact.name}}</h1>
      <p class="contact-line">
        {{contact.email}}&nbsp;&middot;&nbsp;{{contact.phone}}&nbsp;&middot;&nbsp;{{contact.location}}{{#ifExists contact.linkedin}}&nbsp;&middot;&nbsp;<a href="{{contact.linkedin}}">{{contact.linkedin}}</a>{{/ifExists}}{{#ifExists contact.github}}&nbsp;&middot;&nbsp;<a href="{{contact.github}}">{{contact.github}}</a>{{/ifExists}}{{#ifExists contact.website}}&nbsp;&middot;&nbsp;<a href="{{contact.website}}">{{contact.website}}</a>{{/ifExists}}
      </p>
    </header>

    <!-- ── Summary ── -->
    {{#ifExists summary}}
    <section class="section">
      <h2>Summary</h2>
      <p class="summary-text">{{summary}}</p>
    </section>
    {{/ifExists}}

    <!-- ── Experience ── -->
    {{#ifExists experience}}
    <section class="section">
      <h2>Experience</h2>
      {{#each experience}}
      <div class="entry">
        <div class="entry-header">
          <span class="entry-title">{{this.title}}</span>
          <span class="entry-date">{{formatDateRange this.startDate this.endDate}}</span>
        </div>
        <div class="entry-sub">{{this.company}}{{#ifExists this.location}}, {{this.location}}{{/ifExists}}</div>
        {{#ifExists this.bullets}}
        <ul class="bullets">
          {{#each this.bullets}}
          <li><span class="dash">&#8211;</span> {{this}}</li>
          {{/each}}
        </ul>
        {{/ifExists}}
      </div>
      {{/each}}
    </section>
    {{/ifExists}}

    <!-- ── Education ── -->
    {{#ifExists education}}
    <section class="section">
      <h2>Education</h2>
      {{#each education}}
      <div class="entry">
        <div class="entry-header">
          <span class="edu-degree">{{this.degree}}{{#ifExists this.field}} in {{this.field}}{{/ifExists}}</span>
          <span class="edu-date">{{this.graduationDate}}</span>
        </div>
        <div class="entry-sub">{{this.institution}}</div>
      </div>
      {{/each}}
    </section>
    {{/ifExists}}

    <!-- ── Projects ── -->
    {{#ifExists projects}}
    <section class="section">
      <h2>Projects</h2>
      {{#each projects}}
      <div class="entry">
        <div class="entry-header">
          <span class="entry-title">{{this.name}}</span>
        </div>
        {{#ifExists this.description}}
        <p class="project-description">{{this.description}}</p>
        {{/ifExists}}
        {{#ifExists this.technologies}}
        <p class="project-tech">{{joinArray this.technologies ", "}}</p>
        {{/ifExists}}
        {{#ifExists this.bullets}}
        <ul class="bullets">
          {{#each this.bullets}}
          <li><span class="dash">&#8211;</span> {{this}}</li>
          {{/each}}
        </ul>
        {{/ifExists}}
      </div>
      {{/each}}
    </section>
    {{/ifExists}}

    <!-- ── Skills ── -->
    {{#ifExists skills}}
    <section class="section">
      <h2>Skills</h2>
      {{#ifExists skills.languages}}
      <div class="skills-group">
        <span class="skills-label">Languages:</span>{{#each skills.languages}}<span class="skill-pill">{{this}}</span>{{/each}}
      </div>
      {{/ifExists}}
      {{#ifExists skills.frameworks}}
      <div class="skills-group">
        <span class="skills-label">Frameworks:</span>{{#each skills.frameworks}}<span class="skill-pill">{{this}}</span>{{/each}}
      </div>
      {{/ifExists}}
      {{#ifExists skills.tools}}
      <div class="skills-group">
        <span class="skills-label">Tools:</span>{{#each skills.tools}}<span class="skill-pill">{{this}}</span>{{/each}}
      </div>
      {{/ifExists}}
      {{#ifExists skills.other}}
      <div class="skills-group">
        <span class="skills-label">Other:</span>{{#each skills.other}}<span class="skill-pill">{{this}}</span>{{/each}}
      </div>
      {{/ifExists}}
    </section>
    {{/ifExists}}

    <!-- ── Custom Sections ── -->
    {{#ifExists customSections}}
    {{#each customSections}}
    <section class="section">
      <h2>{{this.label}}</h2>
      <p class="custom-content">{{this.content}}</p>
    </section>
    {{/each}}
    {{/ifExists}}

  </div>
</body>
</html>
